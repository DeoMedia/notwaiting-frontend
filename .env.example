# ── Frontend Environment Variables ───────────────────────────
# Copy this to .env.local — Vite loads it automatically.
# Variables must start with VITE_ to be accessible in the browser.

# Canonical public URL of THIS frontend.
# Used to build absolute links (QR codes in /get-mark, the Privacy page,
# the manifesto magic-link target the API embeds in its emails).
# Dev: http://localhost:5173  |  Prod: https://notwaiting.africa
VITE_FRONTEND_URL=http://localhost:5173

# URL of your Express API server
# Dev: http://localhost:3001  |  Prod: https://your-deployed-api.com
VITE_API_URL=http://localhost:3001

# hCaptcha site key — mounts a captcha widget on the manifesto, story,
# and contact forms. The backend re-verifies the resulting token against
# api.hcaptcha.com using HCAPTCHA_SECRET (server-side). Leave empty in
# local dev to skip the captcha (honeypot is still enforced).
# Get yours at: https://dashboard.hcaptcha.com → Sites → New site
VITE_HCAPTCHA_SITE_KEY=

# Sentry (frontend error reporting). When set, every render error +
# unhandled rejection is forwarded to Sentry. Leave empty in dev.
# Create the project at: https://sentry.io → Projects → Create → React
VITE_SENTRY_DSN=
# Fraction of page loads sampled for performance traces. 0.1 = 10%.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
